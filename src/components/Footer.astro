---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="footer-text">© {year} — Built with care.</p>

  <div class="footer-links">
    <a href="https://github.com/Inengs" target="_blank" rel="noopener">GitHub</a>
    <a href="https://linkedin.com/in/emmanuel-inengiye-3a206a289" target="_blank" rel="noopener">LinkedIn</a>
    <a href="https://x.com/inengiyeemmanuel" target="_blank" rel="noopener">X</a>
    <a href="mailto:inengiyeemmanuel@gmail.com">Email</a>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    max-width: var(--page-max);
    margin-inline: auto;
    padding: 40px var(--gutter);
    border-top: 1px solid var(--border);
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-muted);
  }

  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--ink-muted);
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--accent); }
</style>