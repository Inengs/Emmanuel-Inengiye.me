---
const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/writing", label: "Writing" },
  { href: "/open-source", label: "Open Source" },
  { href: "/experience", label: "Experience" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<nav class="sidebar">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo">&gt; Inengs.me</a>

    <!-- Navigation Links -->
    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class={currentPath === link.href || (currentPath === "/" && link.href === "/") ? "active" : ""}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      class="theme-toggle"
      id="theme-toggle"
      onclick="window.__toggleTheme()"
      aria-label="Toggle theme"
    >
    <span class="sun-icon">☀️</span>
    <span class="moon-icon" style="display:none">🌙</span>
    </button>

    <!-- Social Links -->
    <div class="bottom-section"></div>
      <div class="social-links">
        <img src="/IMG_0534.jpeg" alt="Emmanuel" class="avatar" />

        <div class="divider"></div>

         <a href="https://github.com/Inengs" target="_blank" aria-label="GitHub" class="social-link">
          <img src="/github.svg" alt="GitHub" class="social-icon github" />
        </a>
        <a href="https://linkedin.com/in/emmanuel-inengiye-3a206a289" target="_blank" aria-label="LinkedIn" class="social-link">
          <img src="/linkedin.svg" alt="LinkedIn" class="social-icon linkedin" />
        </a>
        <a href="https://instagram.com/_inengs/" target="_blank" aria-label="Instagram" class="social-link">
          <img src="/instagram.svg" alt="Instagram" class="social-icon instagram" />
        </a>
        <a href="https://x.com/inengiyeemmanuel" target="_blank" aria-label="X" class="social-link">
          <svg class="social-icon x-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="/resume.pdf" target="_blank" aria-label="Resume" class="social-link resume-link">
          <svg class="social-icon resume-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 240px;
    background-color: var(--bg);
    border-right: 1px solid var(--border);
    z-index: 50;
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
  }

  .nav-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 13px;
    color: var(--ink);
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .nav-logo:hover { color: var(--accent); }

  .nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 32px;
  }

  .nav-links a {
    display: block;
    font-size: 14px;
    color: var(--ink-muted);
    padding: 6px 12px;
    border-radius: 2px;
    transition: all 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--ink);
    background: var(--accent-bg);
  }

  .nav-links a.active {
    border-left: 2px solid var(--accent);
    padding-left: 10px;
  }

  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    font-size: 16px;
    padding: 8px 12px;
    cursor: pointer;
    align-self: flex-start;
    border-radius: 6px;
    transition: all 0.2s;
    margin-bottom: auto;
  }

  .theme-toggle:hover {
    border-color: var(--ink);
    transform: scale(1.05);
  }

  /* bottom social section */
  .bottom-section {
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .social-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .divider {
    width: 1px;
    height: 16px;
    background: var(--border);
    margin: 0 2px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, opacity 0.2s;
  }

  .social-link:hover {
    transform: translateY(-2px);
    opacity: 0.8;
  }

  .social-icon {
    width: 16px;
    height: 16px;
    display: block;
  }

  /* brand colors */
  .github {
    filter: invert(1);
  }

  :global(:root:not(.dark)) .github {
    filter: invert(0);
  }

  .linkedin {
    filter: invert(35%) sepia(80%) saturate(500%) hue-rotate(175deg) brightness(90%);
  }

  .instagram {
    filter: invert(30%) sepia(80%) saturate(800%) hue-rotate(290deg) brightness(90%);
  }

  .x-icon {
    color: var(--ink);
  }

  .resume-icon {
    color: var(--accent);
  }
</style>