---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const oss = [
  {
    title: "AuthForge",
    description: "Lightweight authentication & authorization service for Go microservices with built-in RBAC and audit logging.",
    year: 2026,
    status: "Active",
    stars: 87,
    forks: 12,
    tech: ["Go", "Fiber", "PostgreSQL", "Redis"],
    url: "https://github.com/Inengs/authforge",
    type: "Maintained"
  },
  {
    title: "QuietLogger",
    description: "Structured logging library with sane defaults, context propagation, and minimal performance overhead.",
    year: 2025,
    status: "Active",
    stars: 64,
    forks: 8,
    tech: ["Go"],
    url: "https://github.com/Inengs/quietlogger",
    type: "Maintained"
  },
  {
    title: "Augur Contribution",
    description: "Major contributions to CHAOSS/Augur — open source software community health analytics platform.",
    year: 2025,
    status: "Contribution",
    stars: 1420,
    forks: 320,
    tech: ["Python", "PostgreSQL"],
    url: "https://github.com/chaoss/augur",
    type: "Contribution"
  },
  {
    title: "Go Rate Limiter",
    description: "Token bucket + sliding window rate limiter with Redis backend support.",
    year: 2024,
    status: "Archived",
    stars: 23,
    forks: 5,
    tech: ["Go", "Redis"],
    url: "https://github.com/Inengs/go-ratelimit",
    type: "Archived"
  },
];

const ossByYear = oss.reduce((acc, item) => {
  acc[item.year] = acc[item.year] || [];
  acc[item.year].push(item);
  return acc;
}, {} as Record<number, typeof oss>);

const sortedYears = Object.keys(ossByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title="Open Source">
  <Navbar />

  <main>
    <section class="oss-page">
      <div class="page-header">
        <div class="prompt">$ ls ~/oss</div>
        <h1>Open Source</h1>
        <p class="intro">Projects I've built or contributed to.</p>
      </div>

      {sortedYears.map((year) => (
        <div class="year-section">
          <div class="year-header">
            <span class="year">{year}</span>
          </div>

          <div class="oss-list">
            {ossByYear[Number(year)].map((project) => (
              <a href={project.url} target="_blank" class="oss-card">
                <div class="card-content">
                  <div class="card-top">
                    <span class={`type ${project.type.toLowerCase()}`}>
                      {project.type}
                    </span>
                    <span class="date">{project.status}</span>
                  </div>

                  <h2 class="title">&gt; {project.title}</h2>
                  
                  <p class="description">{project.description}</p>

                  <div class="tech-stack">
                    {project.tech.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>

                  <div class="stats">
                    <span class="stat">
                      ★ <span>{project.stars}</span>
                    </span>
                    <span class="stat">
                      ⎇ <span>{project.forks}</span>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>
</Layout>

<style>
  main {
    margin-left: 240px;
    max-width: 780px;
    padding: 60px 40px;
  }

  .page-header {
    margin-bottom: 64px;
  }

  .prompt {
    font-size: 13px;
    color: var(--ink-dim);
    margin-bottom: 8px;
  }

  h1 {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .intro {
    font-size: 15px;
    color: var(--ink-muted);
  }

  .year-section {
    margin-bottom: 52px;
  }

  .year-header {
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .year {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .oss-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .oss-card {
    display: block;
    padding: 22px 26px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.25s ease;
    text-decoration: none;
    color: inherit;
  }

  .oss-card:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .type {
    font-size: 10px;
    padding: 2px 10px;
    border: 1px solid var(--border);
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .type.maintained {
    color: var(--accent);
    border-color: var(--accent);
  }

  .type.contribution {
    color: #6b9e6b;
  }

  .type.archived {
    color: var(--ink-dim);
  }

  .date {
    font-size: 11px;
    color: var(--ink-dim);
  }

  .title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--ink);
  }

  .description {
    font-size: 13.2px;
    line-height: 1.65;
    color: var(--ink-muted);
    margin-bottom: 18px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .tag {
    font-size: 10.5px;
    padding: 1px 8px;
    border: 1px solid var(--border);
    color: var(--ink-muted);
  }

  .stats {
    display: flex;
    gap: 18px;
    font-size: 12px;
    color: var(--ink-muted);
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 4px;
  }
</style>