---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const oss = [
  {
    title: "CHAOSS/CollectOSS",
    description: "unit tests for check swapped emails function",
    year: 2026,
    status: "Active",
    stars: 0,
    forks: 0,
    tech: ["python", "pytest"],
    url: "https://github.com/chaoss/CollectOSS/pull/342",
    type: "Maintained"
  },
];

const ossByYear = oss.reduce((acc, item) => {
  acc[item.year] = acc[item.year] || [];
  acc[item.year].push(item);
  return acc;
}, {} as Record<number, typeof oss>);

const sortedYears = Object.keys(ossByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title="Open Source">
  <Navbar />

  <main>
    <div class="page-shell">
      <div class="page-header">
        <p class="eyebrow">$ ls ~/oss</p>
        <h1 class="page-title">Open Source</h1>
        <p class="page-intro">Giving back to the tools I use.</p>
      </div>

      {sortedYears.map((year) => (
        <section class="year-section">
          <div class="year-header">
            <span class="year">{year}</span>
          </div>

          <div class="oss-list">
            {ossByYear[Number(year)].map((project) => (
              <a href={project.url} target="_blank" rel="noopener" class="card oss-card">
                <div class="oss-icon">{"{ }"}</div>

                <div class="oss-body">
                  <div class="card-top">
                    <h2 class="title">{project.title}</h2>
                    <span class={`type ${project.type.toLowerCase()}`}>{project.type}</span>
                  </div>

                  <p class="description">{project.description}</p>

                  <div class="tech-stack">
                    {project.tech.map((t) => <span class="chip">{t}</span>)}
                  </div>

                  <div class="stats">
                    <span class="stat">★ {project.stars}</span>
                    <span class="stat">⎇ {project.forks}</span>
                    <span class="stat status">{project.status}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}

      <p class="footnote">More contributions in progress — check back soon.</p>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .year-section {
    margin-bottom: 40px;
  }

  .year-header {
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .year {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .oss-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .oss-card {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: 32px;
  }

  .oss-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 20px;
    color: var(--accent);
    background: var(--accent-bg);
    border-radius: 10px;
  }

  .oss-body {
    flex: 1;
    min-width: 0;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .title {
    font-family: var(--font-mono);
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
  }

  .type {
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 3px 9px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
  }

  .type.maintained {
    color: var(--accent);
    border-color: var(--accent);
  }

  .type.contribution { color: var(--success); border-color: var(--success); }
  .type.archived { color: var(--ink-dim); }

  .description {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-muted);
    margin-bottom: 16px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .stats {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-dim);
  }

  .stats .status { color: var(--success); }

  .footnote {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-dim);
    margin-top: 24px;
  }

  @media (max-width: 640px) {
    .oss-card {
      flex-direction: column;
      gap: 18px;
      padding: 24px;
    }

    .oss-card:hover { transform: none; }
  }
</style>