---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    title: "Analytics App",
    slug: "adaptiq-test",
    description: "Scalable IoT analytics platform with MQTT data ingestion, ML forecasting, and optimization analytics.",
    tech: ["Node", "Postgres", "Redis", "Next.js", "Docker"],
    year: "2025",
    status: "Staging",
    links: {
      github: "https://github.com/Inengs/analytics-app",
      live: "#"
    }
  },
  {
    title: "BitTorrent Client",
    slug: "bittorrent-client",
    description: "A BitTorrent CLI client built from scratch in Go: parses .torrent files, contacts trackers, connects to peers via TCP, and downloads files using the BitTorrent peer wire protocol.",
    tech: ["Go"],
    year: "2026",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/bittorrent-client",
    }
  },
  {
    title: "Tweet audit",
    slug: "tweetaudit",
    description: "A CLI tool that audits your Twitter/X archive using Gemini AI and flags tweets for deletion based on your own criteria",
    tech: ["Go", "Gemini API"],
    year: "2026",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/tweet-audit",
      live: "#"
    }
  },
  {
    title: "TaskFlow",
    slug: "taskflow",
    description: "Full-stack real-time task manager (Go + React) with WebSockets, PostgreSQL, authentication, and secure REST APIs.",
    tech: ["Go", "React", "Postgres"],
    year: "2025",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/realtime-task-app",
      live: "#"
    }
  },
  {
    title: "Smart Gate App",
    slug: "smartgate",
    description: "Full-stack real-time task manager (Go + React) with WebSockets, PostgreSQL, authentication, and secure REST APIs.",
    tech: ["Firebase", "React-Native"],
    year: "2025",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/Smart-Gate-App",
      live: "https://drive.google.com/file/d/10Ujwi_uDs_Lqlb2G_ll1bY_f_5mYy5TM/view?usp=sharing"
    }
  },
  {
    title: "My Books Directory App",
    slug: "booksdirectory",
    description: "a full-stack web application for managing a collection of books!",
    tech: ["MongoDB", "Express", "HTML", "CSS"],
    year: "2024",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/my-books-directory-app",
      live: "https://my-books-directory-app.onrender.com/"
    }
  },
  // Add more projects here
];

const sortedProjects = projects.sort((a, b) => Number(b.year) - Number(a.year));
---

<Layout title="Projects">
  <Navbar />

  <main>
    <div class="page-shell">
      <div class="page-header">
        <p class="eyebrow">$ ls ~/projects</p>
        <h1 class="page-title">Projects</h1>
        <p class="page-intro">Things I've built that I'm proud of.</p>
      </div>

      <div class="projects-grid">
        {sortedProjects.map((project) => (
          <article class="card project-card">
            <div>
              <div class="card-header">
                <h2 class="project-title">{project.title}</h2>
                <span class="project-year">{project.year}</span>
              </div>

              <p class="project-desc">{project.description}</p>
            </div>

            <div class="card-bottom">
              <div class="tech-stack">
                {project.tech.map((tech) => <span class="chip">{tech}</span>)}
              </div>

              <div class="card-footer">
                <span class="status">{project.status}</span>

                <div class="project-links">
                  {project.links.github && (
                    <a href={project.links.github} target="_blank" rel="noopener">github →</a>
                  )}
                  {project.links.live && (
                    <a href={project.links.live} target="_blank" rel="noopener">live →</a>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    min-height: 240px;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
  }

  .project-title {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-dim);
    white-space: nowrap;
  }

  .project-desc {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .status {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-dim);
  }

  .project-links {
    display: flex;
    gap: 16px;
  }

  .project-links a {
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent);
    transition: opacity 0.2s;
  }

  .project-links a:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-card:hover { transform: none; }
  }

  @media (max-width: 480px) {
    .card-header {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>