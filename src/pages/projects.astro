---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const projects = [
  {
    title: "Analytics App",
    slug: "adaptiq-test",
    description: "Scalable IoT analytics platform with MQTT data ingestion, ML forecasting, and optimization analytics.",
    tech: ["Node", "Postgres", "Redis", "Next.js", "Docker"],
    year: "2025",
    status: "Staging",
    links: {
      github: "https://github.com/Inengs/analytics-app",
      live: "#"
    }
  },
  {
    title: "BitTorrent Client",
    slug: "bittorrent-client",
    description: "A BitTorrent CLI client built from scratch in Go: parses .torrent files, contacts trackers, connects to peers via TCP, and downloads files using the BitTorrent peer wire protocol.",
    tech: ["Go"],
    year: "2026",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/bittorrent-client",
    }
  },
  {
    title: "Tweet audit",
    slug: "tweetaudit",
    description: "A CLI tool that audits your Twitter/X archive using Gemini AI and flags tweets for deletion based on your own criteria",
    tech: ["Go", "Gemini API"],
    year: "2024",
    status: "Internal",
    links: {
      github: "https://github.com/Inengs/tweet-audit",
      live: "#"
    }
  },
  // Add more projects here
];

---

<Layout title="Projects">
  <Navbar />

  <main>
    <section class="projects-page">
      <div class="page-header">
        <div class="prompt">$ ls ~/projects</div>
        <h1>Projects</h1>
        <p class="intro">Things I've built that I'm proud of.</p>
      </div>

      <div class="projects-grid">
        {projects.map((project) => (
          <div class="project-card">
            <div class="card-header">
              <div class="project-title">&gt; {project.title}</div>
              <div class="project-year">{project.year}</div>
            </div>

            <p class="project-desc">{project.description}</p>

            <div class="tech-stack">
              {project.tech.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>

            <div class="card-footer">
              <span class="status">{project.status}</span>
              
              <div class="project-links">
                {project.links.github && (
                  <a href={project.links.github} target="_blank" rel="noopener">github →</a>
                )}
                {project.links.live && (
                  <a href={project.links.live} target="_blank" rel="noopener">live →</a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    margin-left: 240px;
    max-width: 900px;
    padding: 60px 40px;
  }

  .projects-page {
    max-width: 820px;
  }

  .page-header {
    margin-bottom: 60px;
  }

  .prompt {
    font-size: 13px;
    color: var(--ink-dim);
    margin-bottom: 8px;
  }

  h1 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--ink);
  }
 

  .intro {
    font-size: 15px;
    color: var(--ink-muted);
    max-width: 500px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 28px;
  }

  .project-card {
    border: 1px solid var(--border);
    padding: 24px;
    background: var(--bg);
    transition: all 0.25s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .project-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
  }

  .project-year {
    font-size: 11px;
    color: var(--ink-dim);
    white-space: nowrap;
  }

  .project-desc {
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--ink-muted);
    margin-bottom: 20px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .tag {
    font-size: 10.5px;
    padding: 2px 9px;
    border: 1px solid var(--border);
    color: var(--ink-muted);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
  }

  .status {
    color: var(--accent);
    font-weight: 500;
  }

  .project-links {
    display: flex;
    gap: 16px;
  }

  .project-links a {
    color: var(--accent);
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .project-links a:hover {
    opacity: 0.7;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
 
  @media (max-width: 480px) {
    .card-header {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>