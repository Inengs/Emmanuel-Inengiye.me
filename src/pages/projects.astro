---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const projects = [
  {
    title: "Adaptiq / Geutech",
    slug: "adaptiq",
    description: "Production-grade IoT analytics platform. Multi-tenant architecture with real-time data processing and visualization.",
    tech: ["Go", "InfluxDB", "Keycloak", "GCP", "Docker"],
    year: "2024 — Present",
    status: "Production",
    links: {
      github: "#",
      live: "#"
    }
  },
  {
    title: "AuthForge",
    slug: "authforge",
    description: "Lightweight authentication service with session management, RBAC, and audit logging. Built for microservices.",
    tech: ["Go", "PostgreSQL", "Redis", "Fiber"],
    year: "2025",
    status: "Open Source",
    links: {
      github: "https://github.com/Inengs/authforge",
      live: "#"
    }
  },
  {
    title: "QuietStack",
    slug: "quietstack",
    description: "Internal developer platform for managing backend services with focus on observability and reliability.",
    tech: ["Python", "FastAPI", "Prometheus", "Grafana"],
    year: "2024",
    status: "Internal",
    links: {
      github: "#",
      live: "#"
    }
  },
  // Add more projects here
];

---

<Layout title="Projects">
  <Navbar />

  <main>
    <section class="projects-page">
      <div class="page-header">
        <div class="prompt">$ ls ~/projects</div>
        <h1>Projects</h1>
        <p class="intro">Things I've built that I'm proud of.</p>
      </div>

      <div class="projects-grid">
        {projects.map((project) => (
          <div class="project-card">
            <div class="card-header">
              <div class="project-title">&gt; {project.title}</div>
              <div class="project-year">{project.year}</div>
            </div>

            <p class="project-desc">{project.description}</p>

            <div class="tech-stack">
              {project.tech.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>

            <div class="card-footer">
              <span class="status">{project.status}</span>
              
              <div class="project-links">
                {project.links.github && (
                  <a href={project.links.github} target="_blank" rel="noopener">github →</a>
                )}
                {project.links.live && (
                  <a href={project.links.live} target="_blank" rel="noopener">live →</a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    margin-left: 240px;
    max-width: 900px;
    padding: 60px 40px;
  }

  .projects-page {
    max-width: 820px;
  }

  .page-header {
    margin-bottom: 60px;
  }

  .prompt {
    font-size: 13px;
    color: var(--ink-dim);
    margin-bottom: 8px;
  }

  h1 {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--ink);
  }

  .intro {
    font-size: 15px;
    color: var(--ink-muted);
    max-width: 500px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 28px;
  }

  .project-card {
    border: 1px solid var(--border);
    padding: 24px;
    background: var(--bg);
    transition: all 0.25s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .project-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
  }

  .project-year {
    font-size: 11px;
    color: var(--ink-dim);
    white-space: nowrap;
  }

  .project-desc {
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--ink-muted);
    margin-bottom: 20px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .tag {
    font-size: 10.5px;
    padding: 2px 9px;
    border: 1px solid var(--border);
    color: var(--ink-muted);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
  }

  .status {
    color: var(--accent);
    font-weight: 500;
  }

  .project-links {
    display: flex;
    gap: 16px;
  }

  .project-links a {
    color: var(--accent);
    transition: opacity 0.2s;
  }

  .project-links a:hover {
    opacity: 0.7;
  }
</style>