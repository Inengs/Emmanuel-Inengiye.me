---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const writings = [
  {
    title: "What I learned building a BitTorrent client from scratch.",
    date: "March 26, 2026",
    year: 2026,
    category: "Technical",
    url: "https://medium.com/dev-genius/what-i-learned-building-a-bittorrent-client-from-scratch-f3d9eb0dd9ff",
    excerpt: "lessons from building bittorrent client"
  },
  {
    title: "Authentication Broken Down: Passwords, Sessions and JWTs",
    date: "July 4, 2026",
    year: 2026,
    category: "Technical",
    url: "https://medium.com/p/cf5ea11172da",
    excerpt: "Explains on passwords, hashing, sessions, JWT, salting, Bcrypt, Argon2 etc"
  },
];

const writingsByYear = writings.reduce((acc, post) => {
  acc[post.year] = acc[post.year] || [];
  acc[post.year].push(post);
  return acc;
}, {} as Record<number, typeof writings>);

// Sort years descending (newest first)
const sortedYears = Object.keys(writingsByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title="Writing">
  <Navbar />

  <main>
    <div class="page-shell">
      <div class="page-header">
        <p class="eyebrow">$ ls ~/writing</p>
        <h1 class="page-title">Writing</h1>
        <p class="page-intro">Notes on what I've built.</p>
      </div>

      {sortedYears.map((year) => (
        <section class="year-section">
          <div class="year-header">
            <span class="year">{year}</span>
          </div>

          <div class="writing-grid">
            {writingsByYear[Number(year)].map((post) => (
              <a href={post.url} target="_blank" rel="noopener" class="card writing-card">
                <div class="card-top">
                  <span class={`category ${post.category.toLowerCase()}`}>{post.category}</span>
                  <span class="date">{post.date}</span>
                </div>

                <h2 class="title">{post.title}</h2>
                <p class="excerpt">{post.excerpt}</p>

                <span class="read-more">Read more →</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .year-section {
    margin-bottom: 52px;
  }

  .year-section:last-child {
    margin-bottom: 0;
  }

  .year-header {
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .year {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .writing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }

  .writing-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    width: 100%;
    flex-wrap: wrap;
  }

  .category {
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 3px 9px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
  }

  .category.technical {
    color: var(--accent);
    border-color: var(--accent);
  }

  .date {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-dim);
  }

  .title {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .excerpt {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  .read-more {
    margin-top: auto;
    padding-top: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .writing-grid { grid-template-columns: 1fr; }
    .writing-card:hover { transform: none; }
  }

  @media (max-width: 480px) {
    .title { font-size: 17px; }
  }
</style>