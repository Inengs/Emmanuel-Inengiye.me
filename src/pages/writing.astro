---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const writings = [
  {
    title: "Building Resilient Authentication Systems in Go",
    date: "May 26, 2026",
    year: 2026,
    category: "Technical",
    url: "/writing/auth-resilience",
    excerpt: "Lessons from building AuthForge — handling sessions, rate limiting, and audit trails at scale."
  },
  {
    title: "Why I Left Big Tech (for now)",
    date: "April 12, 2026",
    year: 2026,
    category: "Personal",
    url: "/writing/left-big-tech",
    excerpt: "Reflections on burnout, purpose, and choosing depth over velocity."
  },
  {
    title: "Understanding Multi-Tenancy in IoT Platforms",
    date: "March 8, 2026",
    year: 2026,
    category: "Technical",
    url: "/writing/multi-tenancy-iot",
    excerpt: "Architectural patterns used in Adaptiq for data isolation and tenant management."
  },
  {
    title: "A Year of Building in Public",
    date: "December 28, 2025",
    year: 2025,
    category: "Personal",
    url: "/writing/year-in-public",
    excerpt: "What I learned from shipping openly in 2025."
  },
  {
    title: "Observability That Doesn't Hurt",
    date: "October 15, 2025",
    year: 2025,
    category: "Technical",
    url: "/writing/quiet-observability",
    excerpt: "How we built meaningful metrics without drowning in noise."
  },
];

const writingsByYear = writings.reduce((acc, post) => {
  acc[post.year] = acc[post.year] || [];
  acc[post.year].push(post);
  return acc;
}, {} as Record<number, typeof writings>);

// Sort years descending (newest first)
const sortedYears = Object.keys(writingsByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title="Writing">
  <Navbar />

  <main>
    <section class="writing-page">
      <div class="page-header">
        <div class="prompt">$ ls ~/writing</div>
        <h1>Writing</h1>
        <p class="intro">Thoughts, lessons, and experiments.</p>
      </div>

      {sortedYears.map((year) => (
        <div class="year-section">
          <div class="year-header">
            <span class="year">{year}</span>
          </div>

          <div class="writing-list">
            {writingsByYear[Number(year)].map((post) => (
              <a href={post.url} class="writing-card">
                <div class="card-content">
                  <div class="card-top">
                    <span class={`category ${post.category.toLowerCase()}`}>
                      {post.category}
                    </span>
                    <span class="date">{post.date}</span>
                  </div>
                  
                  <h2 class="title">{post.title}</h2>
                  
                  <p class="excerpt">{post.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>
</Layout>

<style>
  main {
    margin-left: 240px;
    max-width: 780px;
    padding: 60px 40px;
  }

  .page-header {
    margin-bottom: 64px;
  }

  .prompt {
    font-size: 13px;
    color: var(--ink-dim);
    margin-bottom: 8px;
  }

  h1 {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .intro {
    font-size: 15px;
    color: var(--ink-muted);
  }

  .year-section {
    margin-bottom: 52px;
  }

  .year-header {
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .year {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .writing-card {
    display: block;
    padding: 20px 24px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.25s ease;
    text-decoration: none;
    color: inherit;
  }

  .writing-card:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .category {
    font-size: 10px;
    padding: 2px 10px;
    border: 1px solid var(--border);
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .category.technical {
    color: var(--accent);
    border-color: var(--accent);
  }

  .category.personal {
    color: var(--ink-muted);
  }

  .date {
    font-size: 11px;
    color: var(--ink-dim);
  }

  .title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--ink);
  }

  .excerpt {
    font-size: 13.2px;
    line-height: 1.6;
    color: var(--ink-muted);
  }
</style>