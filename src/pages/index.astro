---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Emmanuel Inengiye">
  <Navbar />

  <main>
    <section class="hero">
      <div class="prompt">$ whoami</div>

      <h1>Emmanuel Inengiye</h1>

      <p class="tagline">
        <span id="typed"></span><span class="cursor"></span>
      </p>

      <p class="bio">
        i build reliable systems in go, python and typescript
      </p>

      <div class="links">
        <a href="/projects">&gt; see my work</a>
        <a href="mailto:inengiyeemmanuel@gmail.com">&gt; get in touch</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  const phrases = [
    "backend engineer",
    "systems engineer",
    "open source contributor",
  ];

  let phraseIndex = 0;
  let charIndex = 0;
  let deleting = false;
  const el = document.getElementById("typed");

  function tick() {
    if (!el) return;
    const current = phrases[phraseIndex];

    if (!deleting) {
      charIndex++;
      el.textContent = current.slice(0, charIndex);
      if (charIndex === current.length) {
        deleting = true;
        setTimeout(tick, 1800);
        return;
      }
      setTimeout(tick, 80);
    } else {
      charIndex--;
      el.textContent = current.slice(0, charIndex);
      if (charIndex === 0) {
        deleting = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        setTimeout(tick, 400);
        return;
      }
      setTimeout(tick, 45);
    }
  }

  document.addEventListener("DOMContentLoaded", () => tick());
</script>

<style>
  main {
    margin-left: 240px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 0 60px;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 680px;
  }

  .prompt {
    font-size: 12px;
    color: var(--ink-dim);
    letter-spacing: 0.06em;
  }

  h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.05;
    color: var(--ink);
  }

  .tagline {
    font-size: clamp(14px, 2vw, 18px);
    color: var(--accent);
    font-weight: 500;
    min-height: 1.5em;
  }

  .cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background: var(--accent);
    vertical-align: middle;
    margin-left: 6px;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .tagline {
    font-size: 13px;
    color: var(--ink-muted);
  }

  .bio {
    font-size: 14px;
    color: var(--ink-muted);
    max-width: 560px;
    line-height: 1.8;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 8px;
  }

  .links a {
    font-size: 12px;
    color: var(--accent);
    transition: opacity 0.2s;
  }

  .links a:hover { opacity: 0.7; }

  .section-label {
    font-size: 11px;
    color: var(--ink-dim);
    letter-spacing: 0.08em;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 768px) {
    main {
      margin-left: 0;
      padding: 40px 20px;
      min-height: calc(100vh - 56px);
      align-items: flex-start;
      padding-top: 60px;
    }
  }
</style>