---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const stack = ["Go", "Node.js", "Python", "PostgreSQL", "Redis", "Docker", "FastAPI", "AWS"];
---

<Layout title="Emmanuel Inengiye">
  <Navbar />

  <main class="hero-main">
    <section class="hero">
      <!-- Availability pill -->
      <div class="availability">
        <span class="status-dot"></span>
        Open to backend &amp; infrastructure roles
      </div>

      <!-- Big split name with portrait in the middle -->
      <div class="name-stage">
        <h1 class="display-name">
          <span class="name-line line-top">EMMANUEL</span>
          <span class="name-line line-bottom">INENGIYE</span>
        </h1>

        <div class="portrait-wrap">
          <img src="/profile-hero.png" alt="Emmanuel Inengiye" class="portrait" />
        </div>
      </div>

      <!-- Bottom content row -->
      <div class="hero-footer">
        <div class="hero-intro">
          <h2 class="role">Backend Engineer</h2>
          <p class="role-desc">
            I build quiet, reliable systems that scale &mdash; distributed
            systems, IoT platforms &amp; developer tools.
          </p>
          <div class="hero-actions">
            <a href="/projects" class="btn btn-primary">View projects →</a>
            <a href="mailto:inengiyeemmanuel@gmail.com" class="btn btn-secondary">
              Let&rsquo;s collaborate <span class="arrow">&#8599;</span>
            </a>
          </div>
        </div>

        <div class="stack-row">
          {stack.map((s) => <span class="chip-outline">{s}</span>)}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero-main {
    min-height: calc(100vh - var(--nav-h));
    display: flex;
  }

  .hero {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 40px;
    padding: 48px var(--gutter) clamp(32px, 5vh, 56px);
    min-height: calc(100vh - var(--nav-h));
    max-width: var(--page-max);
    margin-inline: auto;
    width: 100%;
    overflow: hidden;
    animation: fadeUp 0.6s ease both;
  }

  /* ── Availability pill ─────────────────────────────── */
  .availability {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-muted);
    padding: 6px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    animation: pulseDot 2.4s ease-in-out infinite;
  }

  /* ── Name + portrait stage ─────────────────────────── */
  .name-stage {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .display-name {
    position: relative;
    z-index: 1;
    width: 100%;
    text-align: center;
    line-height: 0.86;
    letter-spacing: -0.03em;
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(56px, 15.5vw, 220px);
    pointer-events: none;
    user-select: none;
  }

  .name-line {
    display: block;
    white-space: nowrap;
  }

  /* Outlined top line */
  .line-top {
    color: transparent;
    -webkit-text-stroke: 2px var(--ink);
  }

  /* Solid bottom line */
  .line-bottom {
    color: var(--ink);
  }

  .portrait-wrap {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(220px, 34vw, 460px);
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    -webkit-mask-image: linear-gradient(to bottom, #000 78%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 78%, transparent 100%);
    filter: grayscale(1) contrast(1.02);
  }

  /* ── Footer row ────────────────────────────────────── */
  .hero-footer {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
    flex-wrap: wrap;
  }

  .hero-intro {
    max-width: 380px;
  }

  .role {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .role-desc {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--ink-muted);
    margin-bottom: 24px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-actions .btn {
    font-size: 14px;
    padding: 12px 22px;
  }

  .arrow { font-size: 14px; }

  .stack-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    max-width: 400px;
    justify-content: flex-end;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      padding: 32px var(--gutter) 28px;
      gap: 32px;
    }

    .display-name {
      font-size: clamp(44px, 19vw, 120px);
    }

    .line-top {
      -webkit-text-stroke-width: 1.5px;
    }

    .portrait-wrap {
      width: clamp(180px, 56vw, 300px);
    }

    .hero-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 28px;
    }

    .stack-row {
      justify-content: flex-start;
      max-width: none;
    }
  }

  @media (max-width: 420px) {
    .display-name { line-height: 0.92; }
    .portrait-wrap { width: 62vw; }
  }
</style>