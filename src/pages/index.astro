---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Emmanuel Inengiye">
  <Navbar />

  <main class="hero-main">
    <section class="hero">
      <!-- Availability pill -->
      <div class="availability">
        <span class="status-dot"></span>
        Available for New Projects
      </div>

      <!-- Big split name with portrait in the middle -->
      <div class="name-stage">
        <h1 class="display-name">
          <span class="name-line line-top">EMMANUEL</span>
          <span class="name-line line-bottom">INENGIYE</span>
        </h1>

        <div class="portrait-wrap">
          <img src="/profile-hero.png" alt="Emmanuel Inengiye" class="portrait" />
        </div>
      </div>

      <!-- Bottom content row -->
      <div class="hero-footer">
        <div class="hero-intro">
          <h2 class="role">Backend Engineer</h2>
          <p class="role-desc">
            Building quiet, reliable systems that scale &mdash;
            distributed systems, IoT platforms &amp; developer tools.
          </p>
          <a href="mailto:inengiyeemmanuel@gmail.com" class="cta-btn">
            Let&rsquo;s collaborate <span class="arrow">&#8599;</span>
          </a>
        </div>

        <div class="hero-socials">
          <a href="https://github.com/Inengs" target="_blank" rel="noopener" class="social-pill">
            <span>GitHub</span>
          </a>
          <a href="https://linkedin.com/in/emmanuel-inengiye-3a206a289" target="_blank" rel="noopener" class="social-pill">
            <span>LinkedIn</span>
          </a>
          <a href="https://x.com/inengiyeemmanuel" target="_blank" rel="noopener" class="social-pill">
            <span>X / Twitter</span>
          </a>
          <a href="https://instagram.com/_inengs/" target="_blank" rel="noopener" class="social-pill">
            <span>Instagram</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* The hero owns the whole viewport; kill the default sidebar offset
     because the collapsible navbar floats over the hero instead. */
  .hero-main {
    margin-left: 0 !important;
    max-width: none !important;
    padding: 0 !important;
    min-height: 100vh;
    display: flex;
  }

  .hero {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 88px clamp(24px, 5vw, 72px) clamp(32px, 5vh, 56px);
    min-height: 100vh;
    overflow: hidden;
  }

  /* ── Availability pill ─────────────────────────────── */
  .availability {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--ink);
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.18);
  }

  /* ── Name + portrait stage ─────────────────────────── */
  .name-stage {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .display-name {
    position: relative;
    z-index: 1;
    width: 100%;
    text-align: center;
    line-height: 0.86;
    margin: 0;
    letter-spacing: -0.02em;
    font-weight: 800;
    text-transform: uppercase;
    /* Scales the whole treatment fluidly */
    font-size: clamp(56px, 15.5vw, 220px);
    pointer-events: none;
    user-select: none;
  }

  .name-line {
    display: block;
    white-space: nowrap;
  }

  /* Outlined top line */
  .line-top {
    color: transparent;
    -webkit-text-stroke: 2px var(--ink);
  }

  /* Solid bottom line */
  .line-bottom {
    color: var(--ink);
  }

  /* Portrait floats centered, overlapping both name lines */
  .portrait-wrap {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(220px, 34vw, 460px);
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    /* Soft fade at the base so it melts into the layout like the reference */
    -webkit-mask-image: linear-gradient(to bottom, #000 78%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 78%, transparent 100%);
    filter: grayscale(1) contrast(1.02);
  }

  /* ── Footer row ────────────────────────────────────── */
  .hero-footer {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
  }

  .hero-intro {
    max-width: 340px;
  }

  .role {
    font-size: clamp(18px, 2.4vw, 24px);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 8px;
  }

  .role-desc {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--ink-muted);
    margin: 0 0 20px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: var(--bg);
    font-size: 13px;
    font-weight: 500;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s, opacity 0.2s;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }

  .cta-btn .arrow { font-size: 14px; }

  /* Social pills bottom-right */
  .hero-socials {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
  }

  .social-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 130px;
    padding: 9px 18px;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--ink);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .social-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateX(-2px);
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      padding: 72px 20px 28px;
    }

    .display-name {
      font-size: clamp(44px, 19vw, 120px);
    }

    .portrait-wrap {
      width: clamp(180px, 56vw, 300px);
    }

    .hero-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 28px;
    }

    .hero-socials {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .social-pill {
      min-width: 0;
      flex: 1 1 45%;
    }
  }

  @media (max-width: 420px) {
    .display-name { line-height: 0.92; }
    .portrait-wrap { width: 62vw; }
  }
</style>