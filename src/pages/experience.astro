---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const experiences = [
  {
    role: "Backend Engineer",
    company: "Stoxava",
    location: "Houston, Texas (Remote)",
    period: "June 2026 — Present",
    year: 2026,
    description: "Backend development for the stoxava product",
  },
  {
    role: "Software Engineer",
    company: "GEUTech",
    location: "Calgary, Canada (Remote)",
    period: "Nov 2025 — Present",
    year: 2025,
    description: "Building production IoT analytics platform (Adaptiq). Working on multi-tenant architecture, real-time data pipelines, and backend infrastructure.",
  },
  // Add more experiences here in the future
];

const sorted = experiences.sort((a, b) => b.year - a.year);
---

<Layout title="Experience">
  <Navbar />

  <main>
    <div class="page-shell">
      <div class="page-header">
        <p class="eyebrow">$ cat ~/experience.md</p>
        <h1 class="page-title">Experience</h1>
        <p class="page-intro">Where I've worked and what I've built.</p>
      </div>

      <div class="timeline">
        {sorted.map((exp, i) => (
          <div class="timeline-item">
            <div class="dot-col">
              <span class="dot"></span>
              {i < sorted.length - 1 && <span class="line"></span>}
            </div>

            <div class="timeline-content">
              <div class="meta-row">
                <span class="period">{exp.period}</span>
                <span class="location">{exp.location}</span>
              </div>

              <h2 class="role">{exp.role}</h2>
              <p class="company">{exp.company}</p>
              <p class="description">{exp.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 24px;
  }

  .dot-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .line {
    width: 2px;
    flex: 1;
    background: var(--border);
    margin-top: 4px;
  }

  .timeline-content {
    padding-bottom: 48px;
  }

  .timeline-item:last-child .timeline-content {
    padding-bottom: 0;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
  }

  .location {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-dim);
  }

  .role {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .company {
    font-size: 15px;
    color: var(--ink-muted);
    margin-bottom: 12px;
  }

  .description {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-muted);
    max-width: 620px;
  }

  @media (max-width: 480px) {
    .timeline-item { gap: 16px; }
    .timeline-content { padding-bottom: 36px; }
  }
</style>