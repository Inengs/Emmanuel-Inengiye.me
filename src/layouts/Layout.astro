---
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';
import Terminal from '../components/Terminal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Emmanuel Inengiye",
  description = "Backend engineer based in Nigeria. Building systems that run quietly and handle things well.",
} = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/my-logo.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Chatbot />
    <Terminal />

    <script>
      function syncToggle() {
        const isDark = document.documentElement.classList.contains("dark");

        document.querySelectorAll('[aria-label="Toggle theme"]').forEach(btn => {
          const sun = btn.querySelector(".sun-icon") as HTMLElement | null;
          const moon = btn.querySelector(".moon-icon") as HTMLElement | null;
          if (sun) sun.style.display = isDark ? "none" : "inline";
          if (moon) moon.style.display = isDark ? "inline" : "none";
        });
      }

      window.__toggleTheme = () => {
        const isDark = document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", !isDark);
        localStorage.setItem("theme", isDark ? "light" : "dark");
        syncToggle();
      };

      document.addEventListener("DOMContentLoaded", syncToggle);
    </script>
  </body>
</html>

<style is:global>
  /* Desktop sidebar spacing */
  @media (min-width: 769px) {
    main {
      margin-left: 240px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    body {
      padding-top: 56px;
    }

    main {
      margin-left: 0 !important;
      padding: 40px 20px !important;
      max-width: 100% !important;
    }
  }

  /* Ensure terminal trigger is visible */
  .terminal-trigger {
    z-index: 99 !important;
  }

  /* Make sure overlay is on top */
  .terminal-overlay {
    z-index: 200 !important;
  }
</style>