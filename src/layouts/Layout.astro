---
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';
import Terminal from '../components/Terminal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Emmanuel Inengiye",
  description = "Backend engineer based in Nigeria. Building systems that run quietly and handle things well.",
} = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" type="image/png" href="/my-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>

    <!-- Applies the saved theme before first paint so there's no flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const isDark = saved ? saved === "dark" : true;
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>
  <body>
    <slot />
    <Chatbot />
    <Terminal />

    <script>
      function syncToggle() {
        const isDark = document.documentElement.classList.contains("dark");

        document.querySelectorAll('[aria-label="Toggle theme"]').forEach(btn => {
          const sun = btn.querySelector(".sun-icon") as HTMLElement | null;
          const moon = btn.querySelector(".moon-icon") as HTMLElement | null;
          if (sun) sun.style.display = isDark ? "inline" : "none";
          if (moon) moon.style.display = isDark ? "none" : "inline";
        });
      }

      window.__toggleTheme = () => {
        const isDark = document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", !isDark);
        localStorage.setItem("theme", isDark ? "light" : "dark");
        syncToggle();
      };

      syncToggle();
      document.addEventListener("DOMContentLoaded", syncToggle);
    </script>
  </body>
</html>

<style is:global>
  /* The nav is a sticky top bar now, so no page needs a left offset.
     Each page owns its own width via .page-shell. */
  main {
    display: block;
  }

  /* The hero opts out of the standard page padding. */
  main.hero-main {
    padding: 0;
    margin: 0;
    max-width: none;
  }

  .terminal-trigger {
    z-index: 99 !important;
  }

  .terminal-overlay {
    z-index: 200 !important;
  }
</style>